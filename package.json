{
  "name": "path-treeify",
  "version": "1.3.0",
  "description": "Convert a path or an array of paths into a tree-structured JavaScript object, where each node has a `parent` property that holds a circular reference to its parent node.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/index.cjs",
    "dist/index.mjs",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "test": "ava",
    "test:watch": "ava --watch",
    "clean": "rimraf ./dist",
    "build": "npm run clean && rollup -c",
    "build:dev": "NODE_ENV=development npm run build",
    "build:prod": "NODE_ENV=production npm run build",
    "build:watch": "nodemon --watch index.ts -e ts --exec \"npm run build:dev\"",
    "check-publish": "npm pack --dry-run",
    "publish:beta": "npm publish --tag beta --access public",
    "publish:latest": "npm publish --tag latest --access public"
  },
  "ava": {
    "files": [
      "tests/**/*.mjs"
    ],
    "nodeArguments": [
      "--experimental-vm-modules"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaxite/path-treeify.git"
  },
  "bugs": {
    "url": "https://github.com/isaaxite/path-treeify/issues"
  },
  "keywords": [
    "path",
    "tree",
    "treeify",
    "hierarchy",
    "filesystem",
    "object",
    "circular",
    "reference"
  ],
  "author": {
    "name": "isaaxite",
    "url": "https://github.com/isaaxite"
  },
  "license": "MIT",
  "homepage": "https://github.com/isaaxite/path-treeify#readme",
  "sideEffects": false,
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "ava": "^7.0.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
